                                        <span class="h5 lp-selector__title pav-class-hideTestHeading pav-class" pav-class="{&#39;lp-hide&#39;:&#39;hideTestHeading&#39;}"> <span pav-bind="activeFilterName" class="pav-bind"></span> <span>Live Tests</span><a href="https://testbook.com/free-live-tests-and-quizzes" class="test_page" onclick="livePanel.redirectToLiveTest()">Explore</a></span>
                                        <div class="lp-selector__content pav-class-hideTestCategories pav-class pav-class-testShow pav-class-quizShow showTest" pav-class="{&#39;lp-hide&#39;:&#39;hideTestCategories&#39;, &#39;showTest&#39;:&#39;testShow&#39;, &#39;showQuiz&#39;:&#39;quizShow&#39;}">
                                                <div pav-repeat="filterArray" class="pav-repeat grill-pav-repeat"><div class="pav-template">

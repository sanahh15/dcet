<script>
  (function (whatsapp_popup) {
    let currentDomain = window.location.hostname;
    if (!currentDomain.includes("testbook.com")) {
      return;
    }
    let blacklistedUrls = ["login", "creative-login"];
    let currentUrl = window.location.pathname.split("/").slice(1).join("/");
    if (blacklistedUrls.some(url => currentUrl.startsWith(url))) {
      return;
    }
    let tempCookie = {};
    const getClientCookie = (cname) => {
      if (tempCookie[cname]) {
        return tempCookie[cname];
      }
      var ca = document?.cookie?.split?.(';') || [];
      let c, x;
      for (var i = 0; i < ca.length; i++) {
        c = ca[i];
        x = ca[i].split('=');

        if (x[0].trim() === cname) {
          tempCookie[cname] = x.slice(1).join("") || "";

          return tempCookie[cname];
        }
      }
      tempCookie[cname] = '';
      return '';
    }
    if (getClientCookie("tb_token")) {
      return;
    }
    var s = document.createElement("script");
    s.async = true;
    
    s.type = 'text/javascript';
    s.src = "https://whatsappfloatingicon.pages.dev/whatsapp-direction.js";
    s.onload = function () {
    window.generateWAIcon();
  };
    s.onerror = function (err) {
      console.error(err);
    };
    document.body.appendChild(s);
  })("582772e5-3507-480c-9dec-3442a18f94f4");
  </script>    


<script>
  (function() {
    if (!window.location.hostname.includes("plutuseducation.com")) return;

    let promotionManager = null;
    let currentPath = window.location.pathname;
    const bannerId = 'plutusCustomBanner';

    const initPromotionManager = async () => {
      // Remove existing script if it exists
      const existingScript = document.querySelector(`script[src="https://testbook.github.io/plutus-homepage-banner/src/script.js"]`);
      if (existingScript) {
        existingScript.remove();
      }

      // Remove existing banner if it exists
      const existingBanner = document.getElementById(bannerId);
      if (existingBanner) {
        existingBanner.innerHTML = '';
      }

      const script = document.createElement('script');
      script.src = 'https://testbook.github.io/plutus-homepage-banner/src/script.js';
      script.async = true;
      
      script.onload = async () => {
        promotionManager = new PromotionManager(bannerId);
        await promotionManager.init();
        promotionManager.createBanner();
        
        // Show popup only once per session
        if (!sessionStorage.getItem("popupShown")) {
          promotionManager.createPopup();
          sessionStorage.setItem("popupShown", "true");
        }
      };
      
      document.body.appendChild(script);
    };

    // Initial load
    initPromotionManager();

    // Observe route changes
    const observeRouteChanges = () => {
      let lastPath = window.location.pathname;
      
      setInterval(() => {
        if (window.location.pathname !== lastPath) {
          lastPath = window.location.pathname;
          initPromotionManager();
        }
      }, 100);
    };

    observeRouteChanges();
  })();
</script>


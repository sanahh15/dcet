  <style>
    .async-hide body>*:not(#anti-flick-loader) {
      opacity: 1 !important;
    }

    /*body > *:not(#anti-flick-loader){
            //causes issues with other elements which have opacity or transition
            opacity: 1;
            transition: opacity 0.2s ease-in-out;
        }*/
    .async-hide body #anti-flick-loader {
      display: block;
    }

    #login-yolo-container,
    #signup-yolo-container {
      left: -7px;
      top: -5px;
      position: absolute;
    }

    iframe#credential_picker_iframe,
    #credential_picker_container {
      z-index: 9999999999 !important;
    }

    /* #login-yolo-container  iframe , #signup-yolo-container iframe{
            width: 374px !important
        } */

    /* vanilla component styles */
    .default-hidden {
      display: none !important;
    }

    .show-all .default-hidden {
      display: initial !important;
    }

    .show-all .default-hidden.dh--flex {
      display: flex !important;
    }

    .show-all .hide-on-show {
      display: none !important;
    }

    .plutusLoaderUI {
      font-size: 10px;
      width: 1em;
      height: 1em;
      border-radius: 50%;
      position: relative;
      text-indent: -9999em;
      animation: mulShdSpin 1.1s infinite ease;
      transform: translateZ(0);
    }

    @keyframes mulShdSpin {

      0%,
      100% {
        box-shadow: 0em -2.6em 0em 0em #ffffff, 1.8em -1.8em 0 0em rgba(255, 255, 255, 0.2), 2.5em 0em 0 0em rgba(255, 255, 255, 0.2), 1.75em 1.75em 0 0em rgba(255, 255, 255, 0.2), 0em 2.5em 0 0em rgba(255, 255, 255, 0.2), -1.8em 1.8em 0 0em rgba(255, 255, 255, 0.2), -2.6em 0em 0 0em rgba(255, 255, 255, 0.5), -1.8em -1.8em 0 0em rgba(255, 255, 255, 0.7);

                                            </div>
                                            <!-- Add condition for not-allowed class in dropdown category -->
                                            <div class="dropdown__content pav-class-testShow pav-class pav-class-quizShow showTest" pav-class="{&#39;showTest&#39;:&#39;testShow&#39;, &#39;showQuiz&#39;:&#39;quizShow&#39;}">
                                                <div pav-repeat="filterArray" class="pav-repeat grill-pav-repeat"><div class="pav-template">
                                                    <div>
                                                        <div class="dropdown__category" pav-attribute="{&#39;data-filterid&#39;:&#39;_id&#39;}" pav-class="{&#39;lp-hide&#39;:&#39;hideFilter&#39;, &#39;dropdown__category--added&#39;:&#39;isSelected&#39;, &#39;not-allowed&#39;: &#39;@app.testDataLoader&#39;}" onclick="livePanel.callActionOnElement(this,&#39;jumpToCategory&#39;)">

                                                            <img pav-attribute="{&quot;src&quot;:&quot;icon&quot;}" alt="">
                                                            <div>
                                                                <div class="h4" pav-bind="name"></div>
                                                                <!-- Please check this.. have made it according to the design-->
                                                                <span class="testCount"> <span pav-bind="testCount"></span> <span> Tests </span></span>
                                                                <span class="quizCount" pav-class="{&#39;lp-hide&#39;:&#39;hideQuizCount&#39;}">| <span pav-bind="quizCount"> </span><span> Quizzes</span></span>
                                                            </div>
                                                            <span class="cta" pav-class="{&#39;cta--added&#39;:&#39;isSelected&#39;}">
                                                                <span pav-class="{&#39;lp-hide&#39; : &#39;isSelected&#39;}">+</span>
                                                            </span>
                                                        </div>
                                                    </div>
                                                </div></div>
                                                <button class="btn lp-selector__add-cta" onclick="livePanel.submitFilters()">Add Categories</button>
                                        </div>
                                        <div class="lp-ongoing-zero pav-class-hideTestOnCZF pav-class" pav-class="{&#39;lp-hide&#39;:&#39;hideTestOnCZF&#39;}">
                                            <img class="empty-state-img js-lazy-load-img " src="./2020_QP_files/empty-state.svg">
                                            <div class="empty-state-title pav-bind" pav-bind="strings.emptyLiveTestTitle">Live Tests will be added soon</div>
                                            <div class="empty-state-sub-title pav-bind" pav-bind="strings.emptyLiveTestSubTitle">Meanwhile you can practice some questions</div>
                                            <div>
                                                <a class="lp-btn empty-state-btn pav-bind" href="https://testbook.com/practice-questions" target="_self" pav-bind="strings.emptyLiveTestCTA">Start Practice</a>
                                            </div>

    <span>
        <div class="livePanel pav-class-livePanelShow pav-class pav-class-livePanelTabShrunk" pav-class="{&#39;show&#39;:&#39;livePanelShow&#39;,&#39;shrunk&#39;:&#39;livePanelTabShrunk&#39;}">
            <!-- <div class="livePanel__backdrop" pav-class="{'show':'livePanelShow'}"></div> -->
            <div class="tab-area pav-class-livePanelTabShrunk pav-class" pav-class="{&#39;shrunk&#39;:&#39;livePanelTabShrunk&#39;}" onclick="livePanel.lpExpand()">
                <div class="lp-tabs live">
                    <div class="lp-badge-live small pav-bind" pav-bind="strings.livePanelTabTitle">Live</div>
                    <div class="overall-count pav-class-zeroOverallCount pav-class pav-bind" pav-class="{&#39;lp-hide&#39;:&#39;zeroOverallCount&#39;}" pav-bind="overallCount">607</div>
                </div>
                <div class="tab-btns">
                    <div class="lp-tabs shows-bar pav-class-quizzesTabActive pav-class" pav-class="{&#39;lp-active&#39;:&#39;quizzesTabActive&#39;}" onclick="livePanel.showTab(&#39;quizzes&#39;)">
                        <span class="count pav-class-zeroQuizzesCount pav-class pav-class-seenQuizzesCount pav-bind" pav-class="{&#39;lp-hide&#39;:&#39;zeroQuizzesCount&#39;,&#39;greyed&#39;:&#39;seenQuizzesCount&#39;}" pav-bind="quizzesCount">360</span>
                        <img class="lp-icon" src="./2020_QP_files/quizzes.svg">
                        <div class="lp-title pav-bind" pav-bind="strings.quizzes">Quizzes</div>
                    </div>
                    <div class="lp-tabs shows-bar pav-class-testsTabActive pav-class" pav-class="{&#39;lp-active&#39;:&#39;testsTabActive&#39;}" onclick="livePanel.showTab(&#39;tests&#39;)">
                        <span class="count pav-class-zeroTestsCount pav-class pav-class-seenTestsCount pav-bind" pav-class="{&#39;lp-hide&#39;:&#39;zeroTestsCount&#39;,&#39;greyed&#39;:&#39;seenTestsCount&#39;}" pav-bind="testsCount">247</span>
                        <img class="lp-icon" src="./2020_QP_files/tests.svg">
                        <div class="lp-title pav-bind" pav-bind="strings.tests">Tests</div>
                    </div>
                    <div class="lp-tabs shows-bar pav-class-videosTabActive pav-class" pav-class="{&#39;lp-active&#39;:&#39;videosTabActive&#39;}" onclick="livePanel.showTab(&#39;videos&#39;)">
                        <span class="count pav-class-zeroVideosCount pav-class pav-class-seenVideosCount pav-bind lp-hide" pav-class="{&#39;lp-hide&#39;:&#39;zeroVideosCount&#39;,&#39;greyed&#39;:&#39;seenVideosCount&#39;}" pav-bind="videosCount">0</span>
                        <img class="lp-icon" src="./2020_QP_files/classes.svg">
                        <div class="lp-title pav-bind" pav-bind="strings.classes">Classes</div>
                    </div>
                </div>
                <div class="lp-tabs" onclick="livePanel.lpShrink(event)">
                    <svg width="20" height="20" class="expander-btn">
                        <use xlink:href="/assets/img/sprite/home-sprite.svg#circle-arrow"></use>
                    </svg>
                </div>
            </div>
            <div class="lp-tab-content">
                <div class="tab-header" id="tab-header">
                      <span class="tab-text pav-bind" pav-bind="strings.headerTitle">Live</span>
                      <!-- <a><span pav-bind="activeFilterName"></span> <span pav-bind="strings.headerTitle"></span></a> -->
                      <span class="tab-close" onclick="livePanel.showhideLivePanel(&#39;hide&#39;)">
                          <img class="cross-icon" src="./2020_QP_files/close.svg">
                      </span>
                </div>
                <div class="tests lp-tab pav-class-testsTabActive pav-class pav-class-testsLoader" pav-class="{&#39;show&#39;:&#39;testsTabActive&#39;,&#39;lp-loader&#39;:&#39;testsLoader&#39;}"> <!-- onscroll="livePanel.scrollVerticalDetection()" -->
                    <div class="lp-loader"></div>
                    <div class="tab-body">
                        <div class="sub-tabs bg-white">
                            <span class="basic_tab pav-class-testsTabOngoing pav-class pav-bind lp-active" pav-class="{&#39;lp-active&#39;:&#39;testsTabOngoing&#39;}" onclick="livePanel.TabSwitch(&#39;tests&#39;,&#39;ongoing&#39;,this)" pav-bind="strings.ongoing">Ongoing</span>
                            <span class="basic_tab pav-class-testsTabAttempted pav-class pav-bind" pav-class="{&#39;lp-active&#39;:&#39;testsTabAttempted&#39;}" data-login="true" onclick="livePanel.TabSwitch(&#39;tests&#39;,&#39;attempted&#39;,this)" pav-bind="strings.attempted">Attempted</span>
                        </div>
                        <div id="lpTestVerticalScroll" class="sub-tab-body-test pav-class-testsTabOngoing pav-class pav-class-testsTabAttempted pav-class-testAttemptedZero pav-class-testOngoingZero lp-ongoing" pav-class="{&#39;lp-ongoing&#39;:&#39;testsTabOngoing&#39;,&#39;lp-attempted&#39;:&#39;testsTabAttempted&#39;,&#39;lp-attempt-zero&#39;:&#39;testAttemptedZero&#39;,&#39;lp-ongoing-zero&#39;:&#39;testOngoingZero&#39;}" onscroll="livePanel.scrollVerticalDetection()">

                                <div class="lp-selector pav-class-showMoreCategories pav-class" pav-class="{&#39;lp-selector--no-overflow&#39;:&#39;showMoreCategories&#39;}"> <!-- pav-class="{'':'showMoreCategories'}" -->
                                    <div class="lp-selector__heading pav-class-hideTestJumpToCategory pav-class" pav-class="{&#39;lp-hide&#39;:&#39;hideTestJumpToCategory&#39;}">
                                        <img src="./2020_QP_files/test-icon.svg" alt="">
                                        <div class="h3 pav-bind" pav-bind="strings.headTests">Live Tests</div>
                                        <div class="dropdown pav-class-hideJumpToCategory pav-class" pav-class="{&#39;show&#39;:&#39;hideJumpToCategory&#39;}">
                                            <div class="dropdown__btn" onclick="livePanel.toggleDropDown()">

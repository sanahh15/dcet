                                                    </div>
                                                </div></div>
                                            </div>
                                        </div>
                                    </div>
                                    <div class="lp-selector__carousel pav-class-hideTestCarousel pav-class" pav-class="{&#39;lp-hide&#39;:&#39;hideTestCarousel&#39;}">
                                        <div id="lpTestCarouselLeftArrow" class="lp-selector__controller prev pav-class-hideLeftArrow pav-class lp-hide" pav-class="{&#39;lp-hide&#39;:&#39;hideLeftArrow&#39;}" onclick="livePanel.leftScroll()"></div>
                                        <div id="lpTestCarouselRightArrow" class="lp-selector__controller next pav-class-hideRightArrow pav-class" pav-class="{&#39;lp-hide&#39;:&#39;hideRightArrow&#39;}" onclick="livePanel.rightScroll()"></div>
                                        <div id="lpTestCarousel" class="lp-selector__track pav-repeat grill-pav-repeat" pav-repeat="carouselFilterArray" onscroll="livePanel.scrollDetection()"><div class="pav-template">
                                            <div>

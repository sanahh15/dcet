                                                    <span class="h5 d-flex"><span pav-bind="name" pav-class="{&#39;auto-width&#39;:&#39;isMoreCategories&#39;}"></span><img src="./2020_QP_files/blue-bg-plus.svg" class="add-icon" alt=""></span>
                                                    <p class="lp-selector__card__carouselCount"><span pav-bind="testCount"></span> Tests</p>
                                                </div>
                                            </div>
                                        </div></div>
                                    </div>
                                        <!-- this div is for cases when Filter api fails or have length 0 -->
                                        <!-- this lp-hides when filterApiSuccess/filterLengthNonZero are true -->
                                        <!-- rest other divs hide when filterApiFail/filterLengthZero are true -->
                                    <div class="lp-selector__content-empty pav-class-hideTestFilterApiFail pav-class" pav-class="{&#39;lp-hide&#39;:&#39;hideTestFilterApiFail&#39;}">
                                        <img src="./2020_QP_files/empty.svg" alt="Something Went Wrong">
                                        <span class="h3">Something went wrong</span>
                                        <p>Please reload the page or contact our support team</p>
                                    </div>
                                    <!-- This .lp-loader probably need to go inside pav class -->
                                    <div pav-class="{&#39;load-state&#39;:&#39;testDataLoader&#39;}" style="height: 100%;" class="pav-class-testDataLoader pav-class">
                                        <div class="lp-selector__content-wrong pav-class-hideTestFilterLengthZero pav-class" pav-class="{&#39;lp-hide&#39;:&#39;hideTestFilterLengthZero&#39;}">
                                            <img src="./2020_QP_files/fail.webp" alt="No Filters">

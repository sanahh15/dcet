                                            <div>
                                                <span class="lp-btn empty-state-btn pav-class-testOngoingZero pav-class pav-bind" pav-class="{&#39;lp-hide&#39;:&#39;testOngoingZero&#39;}" onclick="livePanel.TabSwitch(&#39;tests&#39;,&#39;ongoing&#39;,this)" pav-bind="strings.emptyLiveTestAttemptCTA">Take Live Test</span>
                                            </div>
                                        </div>
                                        <div class="lp-ongoing pav-class-hideTestOnGoingNonZero pav-class pav-class-testScrollLoader" pav-class="{&#39;lp-hide&#39;:&#39;hideTestOnGoingNonZero&#39;,&#39;load-state&#39;:&#39;testScrollLoader&#39;}">
                                            <div class="lp-loader lp-loader--sm"></div>
                                            <div pav-repeat="testsOngoing" class="pav-repeat grill-pav-repeat"><div class="pav-template">
                                                    <div class="test lp-card ui-card--footer-lang">
                                                        <div class="test-tags tags-single">
                                                            <span class="lp-badge-live dot" pav-class="{&quot;transparent&quot;:&quot;notLiveNow&quot;}" pav-bind="liveStatus"></span>
                                                            <span class="lp-badge-pro" pav-class="{&quot;lp-hide&quot;:&quot;isNotPro&quot;}" pav-bind="isProText"></span>
                                                            <span class="lp-badge-live lp-label" pav-class="{&#39;lp-hide&#39;:&#39;noLabelTag&#39;}" pav-bind="labelTag"></span>
                                                            <span class="lp-badge-scholar" pav-class="{&#39;hidden&#39;:&#39;notScholarshipTest&#39;}">
                                                                <img src="./2020_QP_files/scholartag.svg" alt="icon" height="10" width="10">
                                                                <span pav-bind="scholarshipStatus" style="margin-top: 0;"></span>
                                                            </span>
                                                        </div>
                                                        <div class="test-title" pav-bind="title"></div>
                                                        <div class="test-time" pav-class="{&#39;lp-hide&#39;:&#39;isAttempted&#39;}">
                                                            <span>
                                                                <img class="clock" src="./2020_QP_files/clock.svg">
                                                            </span>
                                                            <span pav-bind="timeStr"></span>
                                                        </div>
                                                        <div pav-class="{&#39;lp-hide&#39;:&#39;isNotAttempted&#39;}">
                                                            <div class="test-time" pav-class="{&quot;blue&quot;:&quot;resultsOut&quot;}" pav-bind="resultStr"></div>
                                                            <div class="test-cta">
                                                                <div class="lp-btn" pav-class="{&quot;lp-outline&quot;:&quot;resultsNotOut&quot;}" pav-attribute="{&#39;data-url&#39;:&#39;url&#39;}" data-login="true" onclick="livePanel.goToDataUrl(this)" pav-bind="buttonText"></div>
                                                            </div>
                                                        </div>
                                                        <div class="test-cta" pav-class="{&#39;lp-hide&#39;:&#39;isAttempted&#39;}">
                                                            <div class="lp-btn" pav-class="{&quot;green&quot;:&quot;notLiveNow&quot;}" pav-attribute="{&#39;data-url&#39;:&#39;url&#39;,&#39;data-event&#39;:&#39;event&#39;}" data-login="true" onclick="livePanel.goToDataUrl(this)" pav-bind="buttonText"></div>
                                                        </div>
                                                        <div class="lang-footer" pav-class="{&#39;hidden&#39;:&#39;hideFooter&#39;}">
                                                            <div pav-class="{&#39;hidden&#39;:&#39;hideSyllabus&#39;}">
                                                                <a href="https://testbook.com/#" pav-attribute="{&quot;data-title&quot;:&quot;description&quot;}">Syllabus</a>
                                                            </div>
                                                            <div class="divider" pav-class="{&#39;hidden&#39;:&#39;hideDivider&#39;, &#39;lp-hide&#39;: &#39;isAttempted&#39;}"></div>
                                                            <div pav-class="{&#39;hidden&#39;:&#39;hideLanguage&#39;, &#39;lp-hide&#39;: &#39;isAttempted&#39;}">
                                                                <div class="lang-box" pav-class="{&#39;hidden&#39;:&#39;hideMoreLanguage&#39;}">
                                                                    <a href="https://testbook.com/#" pav-attribute="{&#39;data-title&#39;:&#39;availLanguagesText&#39;}" pav-bind="remainingLanguagesText"></a> <!--e.g english, hindi +1 more-->
                                                                </div>
                                                                <div class="lang-box" pav-class="{&#39;hidden&#39;:&#39;hideLessLanguage&#39;}">
                                                                    <a href="https://testbook.com/#" pav-attribute="{&#39;data-title&#39;:&#39;availLanguagesText&#39;}" pav-bind="languages"></a> <!--e.g. english, hindi -->
                                                                </div>
                                                            </div>
                                                        </div>
                                                    </div>
                                            </div></div>

                                        </div>
                                        <div class="lp-attempted pav-repeat grill-pav-repeat pav-class-hideTestOnCZF pav-class" pav-class="{&#39;lp-hide&#39;:&#39;hideTestOnCZF&#39;}" pav-repeat="testsAttempted"><div class="pav-template">
                                            <div class="test lp-card ui-card--footer-lang">
                                                <div class="test-tags tags-single">
                                                    <span class="lp-badge-live" pav-bind="liveStatus"></span>
                                                    <span class="lp-badge-live lp-label" pav-class="{&#39;lp-hide&#39;:&#39;noLabelTag&#39;}" pav-bind="labelTag"></span>
                                                    <span class="lp-badge-live dot" pav-class="{&quot;lp-hide&quot;:&quot;isNotPro&quot;}" pav-bind="isProText"></span>
                                                    <span class="lp-badge-scholar" pav-class="{&#39;hidden&#39;:&#39;notScholarshipTest&#39;}">
                                                        <img src="./2020_QP_files/scholartag.svg" alt="icon" height="10" width="10">
                                                        <span pav-bind="scholarshipStatus" style="margin-top: 0;"></span>
                                                    </span>
                                                </div>
                                                <div class="test-title" pav-bind="title"></div>
                                                <div class="test-time" pav-class="{&quot;blue&quot;:&quot;resultsOut&quot;}" pav-bind="resultStr"></div>
                                                <div class="test-cta">
                                                    <div class="lp-btn" pav-class="{&quot;lp-outline&quot;:&quot;resultsNotOut&quot;}" pav-attribute="{&#39;data-url&#39;:&#39;url&#39;}" data-login="true" onclick="livePanel.goToDataUrl(this)" pav-bind="buttonText"></div>
                                                </div>
                                                <div class="lang-footer" pav-class="{&#39;hidden&#39;:&#39;hideSyllabus&#39;}">
                                                    <div><a href="https://testbook.com/#" pav-attribute="{&#39;data-title&#39;:&#39;description&#39;}">Syllabus</a></div>
                                                    <!-- <div>Attempted on 22 Nov</div> -->
                                                </div>
                                            </div>
                                        </div></div>
                                    </div>
                                    <!-- </div> -->
                                </div>
                            </div>
                        </div>
                    </div>
                    <div class="videos lp-tab pav-class-videosTabActive pav-class pav-class-videosLoader" pav-class="{&#39;show&#39;:&#39;videosTabActive&#39;,&#39;lp-loader&#39;:&#39;videosLoader&#39;}">
                        <iframe id="live-panel-iframe" title="Master Class Live Panel" width="100%" height="100%" style="border:none" src="./2020_QP_files/saved_resource(3).html"></iframe>
                    </div>
                    <div class="quizzes lp-tab pav-class-quizzesTabActive pav-class pav-class-quizzesLoader" pav-class="{&#39;show&#39;:&#39;quizzesTabActive&#39;,&#39;lp-loader&#39;:&#39;quizzesLoader&#39;}">
                        <div class="lp-loader"></div>
                        <div class="tab-body">
                            <div class="sub-tabs bg-white">
                                <span class="basic_tab pav-class-quizzesTabOngoing pav-class pav-bind lp-active" pav-class="{&#39;lp-active&#39;:&#39;quizzesTabOngoing&#39;}" onclick="livePanel.TabSwitch(&#39;quizzes&#39;,&#39;ongoing&#39;,this)" pav-bind="strings.ongoing">Ongoing</span>
                                <span class="basic_tab pav-class-quizzesTabAttempted pav-class pav-bind" pav-class="{&#39;lp-active&#39;:&#39;quizzesTabAttempted&#39;}" data-login="true" onclick="livePanel.TabSwitch(&#39;quizzes&#39;,&#39;attempted&#39;,this)" pav-bind="strings.attempted">Attempted</span>
                            </div>
                            <div id="lpQuizVerticalScroll" class="sub-tab-body-quiz pav-class-quizzesTabOngoing pav-class pav-class-quizzesTabAttempted pav-class-quizAttemptedZero pav-class-quizOngoingZero lp-ongoing" pav-class="{&#39;lp-ongoing&#39;:&#39;quizzesTabOngoing&#39;,&#39;lp-attempted&#39;:&#39;quizzesTabAttempted&#39;,&#39;lp-attempt-zero&#39;:&#39;quizAttemptedZero&#39;,&#39;lp-ongoing-zero&#39;:&#39;quizOngoingZero&#39;}" onscroll="livePanel.scrollVerticalDetection()">
                                <div class="lp-selector pav-class-showMoreCategories pav-class" pav-class="{&#39;lp-selector--no-overflow&#39;:&#39;showMoreCategories&#39;}">
                                    <div class="lp-selector__heading pav-class-hideQuizJumpToCategory pav-class" pav-class="{&#39;lp-hide&#39;:&#39;hideQuizJumpToCategory&#39;}">
                                        <img src="./2020_QP_files/test-icon.svg" alt="">
                                        <div class="h3 pav-bind" pav-bind="strings.headQuizzes">Live Quizzes</div>
                                        <div class="dropdown pav-class-hideJumpToCategory pav-class" pav-class="{&#39;show&#39;:&#39;hideJumpToCategory&#39;}">
                                            <div class="dropdown__btn" onclick="livePanel.toggleDropDown()">
                                                Jump to Category
                                            </div>
                                            <div class="dropdown__content pav-class-testShow pav-class pav-class-quizShow showTest" pav-class="{&#39;showTest&#39;:&#39;testShow&#39;, &#39;showQuiz&#39;:&#39;quizShow&#39;}">
                                                <div pav-repeat="filterArray" class="pav-repeat grill-pav-repeat"><div class="pav-template">
                                                        <div>
                                                            <div class="dropdown__category" pav-attribute="{&#39;data-filterid&#39;:&#39;_id&#39;}" pav-class="{&#39;lp-hide&#39;:&#39;hideFilter&#39;, &#39;dropdown__category--added&#39;:&#39;isSelected&#39;, &#39;not-allowed&#39;: &#39;@app.quizDataLoader&#39;}" onclick="livePanel.callActionOnElement(this,&#39;jumpToCategory&#39;)">
                                                                <div>
                                                                    <div class="h4" pav-bind="name"></div>
                                                                    <p class="testCount"><span pav-bind="testCount"></span> Tests</p>
                                                                    <p class="quizCount"><span pav-bind="quizCount"></span> Quizzes</p>
                                                                </div>
                                                            </div>
                                                        </div>
                                                    <!-- '.dropdown__category--added' adds a blue circle with tick mark, Selection of the category is done on click of this whole category div.   -->
                                                </div></div>
                                            </div>
                                        </div>
                                    </div>
                                    <div class="lp-selector__carousel pav-class-hideQuizCarousel pav-class" pav-class="{&#39;lp-hide&#39;:&#39;hideQuizCarousel&#39;}">
                                        <div id="lpQuizCarouselLeftArrow" class="lp-selector__controller prev pav-class-hideLeftArrow pav-class lp-hide" pav-class="{&#39;lp-hide&#39;:&#39;hideLeftArrow&#39;}" onclick="livePanel.leftScroll()"></div>
                                        <div id="lpQuizCarouselRightArrow" class="lp-selector__controller next pav-class-hideRightArrow pav-class" pav-class="{&#39;lp-hide&#39;:&#39;hideRightArrow&#39;}" onclick="livePanel.rightScroll()"></div>
                                        <div id="lpQuizCarousel" class="lp-selector__track pav-repeat grill-pav-repeat" pav-repeat="carouselFilterArray" onscroll="livePanel.scrollDetection()"><div class="pav-template">
                                            <div>
                                                <div class="lp-selector__card" pav-attribute="{&#39;data-filterid&#39;:&#39;_id&#39;}" pav-class="{&#39;active&#39;:&#39;activeFilter&#39;, &#39;lp-hide&#39;:&#39;isNotSelected&#39;, &#39;moreCategories&#39; : &#39;isMoreCategories&#39;, &#39;not-allowed&#39;: &#39;@app.quizDataLoader&#39;}" onclick="livePanel.callActionOnElement(this,&#39;applyFilter&#39;)">
                                                    <span class="h5 d-flex"><span pav-bind="name" pav-class="{&#39;auto-width&#39;:&#39;isMoreCategories&#39;}"></span><img src="./2020_QP_files/blue-bg-plus.svg" class="add-icon" alt=""></span>
                                                    <p class="lp-selector__card__carouselCount"><span pav-bind="quizCount"></span> Quizzes</p>
                                                </div>
                                            </div>
                                        </div></div>
                                    </div>

                                    <div class="lp-selector__content-empty pav-class-hideQuizFilterApiFail pav-class" pav-class="{&#39;lp-hide&#39;:&#39;hideQuizFilterApiFail&#39;}">
                                        <img src="./2020_QP_files/empty.svg" alt="Something Went Wrong">
                                        <span class="h3">Something went wrong</span>
                                        <p>Please reload the page or contact our support team</p>
                                    </div>

                                    <div pav-class="{&#39;load-state&#39;:&#39;quizDataLoader&#39;}" style="height: 100%;" class="pav-class-quizDataLoader pav-class">
                                        <div class="lp-loader"></div>
                                        <div class="lp-selector__content-wrong pav-class-hideQuizFilterLengthZero pav-class" pav-class="{&#39;lp-hide&#39;:&#39;hideQuizFilterLengthZero&#39;}">
                                            <img src="./2020_QP_files/fail.webp" alt="No Filters">
                                            <span class="h3">No live Tests &amp; Quizzes Found</span>
                                            <p>We don't have any live tests or quizzes at this time. Please check after sometime </p>
                                        </div>

                                        <!-- Add binding here for name -->
                                        <span class="h5 lp-selector__title pav-class-hideQuizHeading pav-class" pav-class="{&#39;lp-hide&#39;:&#39;hideQuizHeading&#39;}">  <span pav-bind="activeFilterName" class="pav-bind"></span> <span>Live Quizzes</span><a href="https://testbook.com/free-live-tests-and-quizzes" class="test_page" onclick="livePanel.redirectToLiveTest()">Explore</a></span>
                                        <div class="lp-selector__content pav-class-hideQuizCategories pav-class pav-class-testShow pav-class-quizShow showTest" pav-class="{&#39;lp-hide&#39;:&#39;hideQuizCategories&#39;, &#39;showTest&#39;:&#39;testShow&#39;, &#39;showQuiz&#39;:&#39;quizShow&#39;}">
                                            <div pav-repeat="filterArray" class="pav-repeat grill-pav-repeat"><div class="pav-template">
                                                <div>
                                                    <div class="lp-selector__category" pav-attribute="{&#39;data-filterid&#39;:&#39;_id&#39;}" pav-class="{&#39;lp-hide&#39;:&#39;hideFilter&#39;}" onclick="livePanel.callActionOnElement(this, &#39;addFilter&#39;)">
                                                        <img pav-attribute="{&quot;src&quot;:&quot;icon&quot;}" alt="">
                                                        <div>
                                                            <div class="h4" pav-bind="name"></div>
                                                            <!-- Please check this.. have made it according to the design-->
                                                            <span class="testCount" pav-class="{&#39;lp-hide&#39;:&#39;hideTestCount&#39;}"> <span pav-bind="testCount"> </span><span> Tests |</span></span>
                                                            <span class="quizCount"> <span pav-bind="quizCount"></span> <span> Quizzes</span></span>
                                                        </div>
                                                        <span class="cta" pav-class="{&#39;cta--added&#39;:&#39;isSelected&#39;}">
                                                            <span pav-class="{&#39;lp-hide&#39; : &#39;isSelected&#39;}">+</span>
                                                        </span>
                                                    </div>
                                                </div>
                                            </div></div>
                                            <button class="btn lp-selector__add-cta" onclick="livePanel.submitFilters()">Add Categories</button>
                                        </div>
                                        <div class="lp-ongoing-zero pav-class-hideTestOnCZF pav-class" pav-class="{&#39;lp-hide&#39;:&#39;hideTestOnCZF&#39;}">
                                            <img class="empty-state-img" src="./2020_QP_files/empty-state.svg">
                                            <div class="empty-state-title pav-bind" pav-bind="strings.emptyLiveQuizTitle">Live Quizzes will be added soon</div>
                                            <div class="empty-state-sub-title pav-bind" pav-bind="strings.emptyLiveQuizSubTitle">Meanwhile you can practice some questions</div>
                                            <div>
                                                <a class="lp-btn empty-state-btn pav-bind" href="https://testbook.com/practice-questions" target="_self" pav-bind="strings.emptyLiveQuizCTA">Start Practice</a>
                                            </div>
                                        </div>
                                        <div class="lp-attempt-zero pav-class-hideTestOnCZF pav-class" pav-class="{&#39;lp-hide&#39;:&#39;hideTestOnCZF&#39;}">
                                            <img src="./2020_QP_files/empty.svg" alt="Something Went Wrong">
                                            <div class="empty-state-title pav-bind" pav-bind="strings.emptyLiveQuizAttemptTitle">You haven't attempted any Live Quiz</div>
                                            <div class="empty-state-sub-title pav-bind" pav-bind="strings.emptyLiveQuizAttemptSubTitle">Attempted quizzes will appear here</div>
                                            <div>
                                                <span class="lp-btn empty-state-btn pav-class-quizOngoingZero pav-class pav-bind" pav-class="{&#39;lp-hide&#39;:&#39;quizOngoingZero&#39;}" onclick="livePanel.TabSwitch(&#39;quizzes&#39;,&#39;ongoing&#39;,this)" pav-bind="strings.emptyLiveQuizAttemptCTA">Take Live Quiz</span>
                                            </div>
                                        </div>
                                        <!-- Need to add load-state class here , so that loader at bottom can be seen -->
                                        <div class="lp-ongoing pav-class-hideQuizOnGoingNonZero pav-class pav-class-quizScrollLoader" pav-class="{&#39;lp-hide&#39;:&#39;hideQuizOnGoingNonZero&#39;,&#39;load-state&#39;:&#39;quizScrollLoader&#39;}">
                                            <div class="lp-loader lp-loader--sm"></div>
                                            <div pav-repeat="testsOngoing" class="pav-repeat grill-pav-repeat"><div class="pav-template">
                                                <div class="quiz lp-card ui-card--footer-lang">
                                                    <div class="quiz-tags tags-single">
                                                        <span class="lp-badge-live dot" pav-class="{&quot;transparent&quot;:&quot;notLiveNow&quot;}" pav-bind="liveStatus"></span>
                                                        <span class="lp-badge-live lp-label" pav-class="{&#39;lp-hide&#39;:&#39;noLabelTag&#39;}" pav-bind="labelTag"></span>
                                                    </div>
                                                    <div class="quiz-title" pav-bind="title"></div>
                                                    <div class="quiz-time" pav-class="{&#39;lp-hide&#39;:&#39;isAttempted&#39;}">
                                                        <span>
                                                            <img class="clock" src="./2020_QP_files/clock.svg">
                                                        </span>
                                                        <span pav-bind="timeStr"></span>
                                                    </div>
                                                    <div pav-class="{&#39;lp-hide&#39;:&#39;isNotAttempted&#39;}">
                                                        <div class="quiz-time" pav-class="{&quot;blue&quot;:&quot;resultsOut&quot;}" pav-bind="resultStr"></div>
                                                        <div class="quiz-cta">
                                                            <div class="lp-btn" pav-class="{&quot;lp-outline&quot;:&quot;resultsNotOut&quot;}" pav-attribute="{&#39;data-url&#39;:&#39;url&#39;}" data-login="true" onclick="livePanel.goToDataUrl(this)" pav-bind="buttonText"></div>
                                                        </div>
                                                    </div>
                                                    <div class="quiz-cta" pav-class="{&#39;lp-hide&#39;:&#39;isAttempted&#39;}">
                                                        <div class="lp-btn" pav-class="{&quot;green&quot;:&quot;notLiveNow&quot;}" pav-attribute="{&#39;data-url&#39;:&#39;url&#39;,&#39;data-event&#39;:&#39;event&#39;}" data-login="true" onclick="livePanel.goToDataUrl(this)" pav-bind="buttonText"></div>
                                                    </div>
                                                    <div class="lang-footer" pav-class="{&#39;hidden&#39;:&#39;hideFooter&#39;}">
                                                        <div pav-class="{&#39;hidden&#39;:&#39;hideSyllabus&#39;}">
                                                            <a href="https://testbook.com/#" pav-attribute="{&quot;data-title&quot;:&quot;description&quot;}">Syllabus</a>
                                                        </div>
                                                        <div class="divider" pav-class="{&#39;hidden&#39;:&#39;hideDivider&#39;, &#39;lp-hide&#39;: &#39;isAttempted&#39;}"></div>
                                                        <div pav-class="{&#39;hidden&#39;:&#39;hideLanguage&#39;, &#39;lp-hide&#39;: &#39;isAttempted&#39;}">
                                                            <div class="lang-box" pav-class="{&#39;hidden&#39;:&#39;hideMoreLanguage&#39;}">
                                                                <a href="https://testbook.com/#" pav-attribute="{&#39;data-title&#39;:&#39;availLanguagesText&#39;}" pav-bind="remainingLanguagesText"></a> <!--e.g english, hindi +1 more-->
                                                            </div>
                                                            <div class="lang-box" pav-class="{&#39;hidden&#39;:&#39;hideLessLanguage&#39;}">
                                                                <a href="https://testbook.com/#" pav-attribute="{&#39;data-title&#39;:&#39;availLanguagesText&#39;}" pav-bind="languages"></a> <!--e.g. english, hindi -->
                                                            </div>
                                                        </div>
                                                    </div>
                                                </div>
                                            </div></div>

                                        </div>
                                        <div class="lp-attempted pav-repeat grill-pav-repeat pav-class-hideQuizOnCZF pav-class" pav-class="{&#39;lp-hide&#39;:&#39;hideQuizOnCZF&#39;}" pav-repeat="testsAttempted"><div class="pav-template">
                                            <div class="quiz lp-card ui-card--footer-lang">
                                                <div class="quiz-tags tags-single">
                                                    <span class="lp-badge-live" pav-bind="liveStatus"></span>
                                                    <span class="lp-badge-live lp-label" pav-class="{&#39;lp-hide&#39;:&#39;noLabelTag&#39;}" pav-bind="labelTag"></span>
                                                </div>
                                                <div class="quiz-title" pav-bind="title"></div>
                                                <div class="quiz-time" pav-class="{&quot;blue&quot;:&quot;resultsOut&quot;}" pav-bind="resultStr"></div>
                                                <div class="quiz-cta">
                                                    <div class="lp-btn" pav-class="{&quot;lp-outline&quot;:&quot;resultsNotOut&quot;}" pav-attribute="{&#39;data-url&#39;:&#39;url&#39;}" data-login="true" onclick="livePanel.goToDataUrl(this)" pav-bind="buttonText"></div>
                                                </div>
                                                <div class="lang-footer" pav-class="{&#39;hidden&#39;:&#39;hideFooter&#39;}">
                                                    <div pav-class="{&#39;hidden&#39;:&#39;hideSyllabus&#39;}">
                                                        <a href="https://testbook.com/#" pav-attribute="{&quot;data-title&quot;:&quot;description&quot;}">Syllabus</a>
                                                    </div>
                                                </div>
                                            </div>
                                        </div></div>
                                    </div>
                                </div>
                            </div>
                        </div>
                    </div>
                </div>
        </div>
        <div class="lp-fade pav-class-livePanelShow pav-class" pav-class="{&#39;show&#39;:&#39;livePanelShow&#39;}" onclick="livePanel.showhideLivePanel(&#39;hide&#39;)"></div>

        <div class="lp-login-modal" id="lp-login-modal" tabindex="-1" role="dialog" data-keyboard="false" data-backdrop="static">
            <div id="lp-close-btn" data-dismiss="modal" onclick="livePanel.closeOnboardingModal()" class="lp-tb-close"></div>
            <div class="lp-iframe-container">
                <div>
                    <div class="main-loader"></div>
                </div>
                <iframe name="lp-onBoardingIframeName" id="lp-onBoardingIframe" class="lp-login-modal-iframe pav-attribute-onboardingUrl pav-attribute" src="./2020_QP_files/saved_resource(4).html" pav-attribute="{&#39;src&#39;:&#39;onboardingUrl&#39;}" style="position: relative;width:100%" frameborder="0"></iframe>
            </div>
        </div>
        <div class="lp-login-modal-fade pav-class-onboardingShow pav-class" pav-class="{&#39;show&#39;:&#39;onboardingShow&#39;}" onclick="livePanel.closeOnboardingModal()"></div>
    </span>
</div></body></html>